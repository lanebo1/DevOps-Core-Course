{
  "id": null,
  "uid": "app-logs-dashboard",
  "title": "Application Logs",
  "description": "Centralized log dashboard for DevOps apps",
  "tags": ["loki", "logs", "devops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Application Logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{app=~\"devops-.*\"}",
          "legendFormat": "{{app}}"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (logs/sec by app)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (app) (rate({app=~\"devops-.*\"}[1m]))",
          "legendFormat": "{{app}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{app=~\"devops-.*\"} | json | level=`ERROR`",
          "legendFormat": "{{app}} errors"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "wrapLogMessage": true
      }
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Log Level Distribution",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (level) (count_over_time({app=~\"devops-.*\"} | json [5m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Log Lines (last 5m)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum(count_over_time({app=~\"devops-.*\"}[5m]))",
          "legendFormat": "Total logs"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } }
      }
    }
  ]
}
